{
  "manifest_version": 3,
  "name": "Therapheye Screen Guard",
  "version": "1.9.0",
  "description": "Monitorea tu tiempo de pantalla y recibe recordatorios 20-20-20 para cuidar tu visión.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Therapheye Screen Guard",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "activeTab",
    "idle",
    "offscreen",
    "windows"
  ],
  "host_permissions": ["<all_urls>"]
}
